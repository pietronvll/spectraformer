# clean all the other saved models
saved_models/checkpoints/*
# keep the spectraformer:min70_highf model
!saved_models/checkpoints/spectraformer:min70_highf/
# clean all the steps inside the model folder
saved_models/checkpoints/spectraformer:min70_highf/*
# but keep the last step 59925
!saved_models/checkpoints/spectraformer:min70_highf/59925/
# and its content
!saved_models/checkpoints/spectraformer:min70_highf/59925/*
# same for metadata
!saved_models/checkpoints/spectraformer:min70_highf/metadata/
!saved_models/checkpoints/spectraformer:min70_highf/metadata/*


